DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID="replace-with-google-web-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-web-client-secret"

# Required for macOS desktop computer-use through OpenAI.
OPENAI_API_KEY="replace-with-openai-api-key"

# Optional hosted inference providers.
ELEVENLABS_API_KEY="replace-with-elevenlabs-api-key"

# Required for Gemini / Google Cloud inference through Vertex AI. The adapter
# uses the global endpoint and derives the project from project_id.
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account",...}'

# Dev-only: a Gemini Developer API key. When set, the Live client connects
# directly to the Developer API (using GEMINI_LIVE_MODEL; the client default is an
# audio-output-only model) instead of minting a Vertex token. Production uses the
# keyless Vertex path above.
GEMINI_API_KEY="replace-with-gemini-api-key"

# RunPod-hosted vision worker, served by /api/inference/vision (see
# vision/README.md). Required for that route; unrelated to the gemini-flash
# screenshot parser at /api/inference/screenshots/parse.
RUNPOD_API_KEY="replace-with-runpod-api-key"
RUNPOD_VISION_ENDPOINT_ID="replace-with-endpoint-id"

# Stripe. Two separate subscription products plus one-time credit top-ups all
# run through STRIPE_SECRET_KEY and the /api/billing/webhook endpoint (signed by
# STRIPE_WEBHOOK_SECRET).
#   STRIPE_VISION_PRICE_ID — recurring price for the Vision API plan; metadata
#     key "monthlyCallQuota" tunes the included call quota without a deploy.
#   STRIPE_PRO_PRICE_ID — recurring price for the Donkey Pro app plan; the
#     included monthly inference allowance equals this price (a $20/mo plan
#     includes $20 of inference), read straight from the price's amount.
STRIPE_SECRET_KEY="replace-with-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="replace-with-stripe-webhook-signing-secret"
STRIPE_VISION_PRICE_ID="replace-with-stripe-price-id"
STRIPE_PRO_PRICE_ID="replace-with-stripe-pro-price-id"
STRIPE_PORTAL_CONFIGURATION_ID="replace-with-stripe-portal-configuration-id"

# Browser Use Cloud (agentic web automation via /api/browser/run). Backend-only
# secret; the Mac app never carries it. Key starts with "bu_".
BROWSER_USE_API_KEY="replace-with-browser-use-api-key"

# PostHog analytics (client-side project key; public by design, inlined at build).
# Leave unset to disable tracking (e.g. local dev).
NEXT_PUBLIC_POSTHOG_KEY="replace-with-posthog-project-key"
