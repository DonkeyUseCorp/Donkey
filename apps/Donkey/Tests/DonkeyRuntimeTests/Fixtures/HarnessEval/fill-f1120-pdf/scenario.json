{
  "frontmostApp": "Finder",
  "maxSteps": 16,
  "disk": [
    { "path": "f1120.pdf", "describe": "AcroForm PDF, 6 pages, 48 fillable fields (text and checkbox)." },
    { "path": "1120data.txt", "describe": "UTF-8 text, 12 `key: value` lines.", "contentFile": "1120data.txt" }
  ],
  "responses": [
    { "tool": "shell_exec", "contains": ["pdf-fill", "field"], "summary": "{\"type\":\"acroform\",\"fields\":[{\"name\":\"f1_01\",\"type\":\"text\"},{\"name\":\"c1_1\",\"type\":\"checkbox\"}]}" },
    { "tool": "shell_exec", "contains": ["pdf-fill"], "summary": "Wrote f1120-filled.pdf (48 fields set).", "produces": ["f1120-filled.pdf"] }
  ],
  "expect": {
    "turnKind": "act",
    "skills": ["pdf"],
    "shellAny": [["pdf-fill"], ["lit"]]
