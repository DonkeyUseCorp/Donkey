{
  "frontmostApp": "Finder",
  "maxSteps": 18,
  "disk": [
    { "path": "~/Desktop/scans", "describe": "Folder of 8 scanned PDFs, ~3MB each (24MB total)." },
    { "path": "~/Desktop/scans/scan-01.pdf", "describe": "Scanned PDF, ~3MB." },
    { "path": "~/Desktop/scans/scan-02.pdf", "describe": "Scanned PDF, ~3MB." },
    { "path": "~/Desktop/scans/scan-03.pdf", "describe": "Scanned PDF, ~3MB." },
    { "path": "~/Desktop/scans/scan-04.pdf", "describe": "Scanned PDF, ~3MB." },
    { "path": "~/Desktop/scans/scan-05.pdf", "describe": "Scanned PDF, ~3MB." },
    { "path": "~/Desktop/scans/scan-06.pdf", "describe": "Scanned PDF, ~3MB." },
    { "path": "~/Desktop/scans/scan-07.pdf", "describe": "Scanned PDF, ~3MB." },
    { "path": "~/Desktop/scans/scan-08.pdf", "describe": "Scanned PDF, ~3MB." }
  ],
  "responses": [
    { "tool": "shell_exec", "contains": ["qpdf"], "summary": "Combined the 8 scans into scans-combined.pdf, then downsampled to 4.2MB.", "produces": ["scans-combined.pdf"] },
    { "tool": "shell_exec", "contains": ["pdfunite"], "summary": "Combined the 8 scans into scans-combined.pdf.", "produces": ["scans-combined.pdf"] },
    { "tool": "shell_exec", "contains": ["gs"], "summary": "Downsampled scans-combined.pdf to 4.2MB.", "produces": ["scans-combined.pdf"] }
  ],
  "expect": {
    "turnKind": "act",
    "skills": ["pdf"],
    "shellAny": [["qpdf"], ["gs"], ["ghostscript"], ["pdfunite"]]
  }
}
